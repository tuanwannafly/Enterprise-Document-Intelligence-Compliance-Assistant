# =============================================================================
# Enterprise Document Intelligence & Compliance Assistant - Configuration
# =============================================================================
# Copy to `.env` and adjust. All values shown are safe local-development defaults;
# production MUST override secrets via AWS Secrets Manager / Parameter Store.
# =============================================================================

# --- Application -------------------------------------------------------------
APP_NAME=enterprise-doc-intelligence
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- AWS --------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme

# S3 bucket for raw uploaded documents
DOCUMENTS_BUCKET=edi-documents-dev
# S3 prefix for redacted text artifacts
REDACTED_PREFIX=redacted/
# S3 prefix for OCR text artifacts
OCR_PREFIX=ocr/

# --- Textract / Comprehend / Bedrock ----------------------------------------
TEXTRACT_ASYNC_POLL_SECONDS=5
TEXTRACT_ASYNC_TIMEOUT_SECONDS=600

# Restrict PII entity detection to reduce false positives and cost
PII_ENTITY_TYPES=NAME,EMAIL,PHONE,SSN,ADDRESS,BANK_ACCOUNT_NUMBER,CREDIT_DEBIT_NUMBER

BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- Database (Postgres) ----------------------------------------------------
DATABASE_URL=postgresql+psycopg2://edi:edi@localhost:5432/edi
# Set to true in production; when false, RLS BYPASS is available for service role
ENABLE_RLS=true

# --- Auth (Cognito / JWT) ---------------------------------------------------
# In dev mode we accept a simple shared secret so the API is testable without
# provisioning a real Cognito user pool.
DEV_AUTH_MODE=true
DEV_AUTH_SHARED_SECRET=dev-only-do-not-use-in-prod
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_JWKS_URL=

# --- Vector store selection -------------------------------------------------
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=edi_chunks

OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=edi_chunks

# --- Feature flags ----------------------------------------------------------
ENABLE_STREAMING=true
ENABLE_AUDIT_LOG=true
ENABLE_PII_REDACTION=true
